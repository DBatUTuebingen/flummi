ENTRYPOINT entry
INPUTS ()
EMITS §text§
VARS (
  poh : §struct(label text, loc point)§, 
  poh0 : §struct(label text, loc point)§, 
  condition%0 : §bool§
)
BLOCKS {
  BLOCK entry ()
  []
  {
    poh0 <- §SELECT p FROM points AS p ORDER BY p.loc.x LIMIT 1§[];
    GOTO inter0 ()
  }

  BLOCK inter0 ()
  []
  {
    poh <- §{0}§[poh0];
    GOTO inter1 ()
  }

  BLOCK inter1 ()
  []
  {
    GOTO loop0_head ()
  }

  BLOCK loop0_head ()
  []
  {
    EMIT §{0}.label§[poh];
    GOTO inter2 ()
  }

  BLOCK loop0_exit ()
  []
  {
    STOP
  }

  BLOCK inter2 ()
  []
  {
    poh <- §SELECT p1 FROM points AS p1 WHERE p1 <> {0} AND NOT EXISTS (SELECT 1 FROM points AS p2 WHERE left_of(p2.loc, {0}.loc, p1.loc))§[poh];
    GOTO inter3 ()
  }

  BLOCK inter3 ()
  []
  {
    condition%0 <- §{0} = {1}§[poh, poh0];
    GOTO inter4 ()
  }

  BLOCK truthy0 ()
  []
  {
    STOP
  }

  BLOCK falsey0 ()
  []
  {
    GOTO loop0_head ()
  }

  BLOCK merge0 ()
  []
  {
    GOTO loop0_head ()
  }

  BLOCK inter4 ()
  []
  {
    IF condition%0
    THEN GOTO truthy0 ()
    ELSE GOTO falsey0 ()
  }

  BLOCK unreachable0 ()
  []
  {
    GOTO merge0 ()
  }
}
JUMPS []