CALL (§4§[], §5§[]) IN
FUN (a: §int§, b: §int§) -> §int§: {
  d: §int§;
  c: §int§;
  b <- §1§[];

  LOOP loop {
    b <- §{0} + 1§[b];
    LOOP loop2 {
      d <- §3§[];
      condition: §bool§;
      condition <- §2 = {0}§[b];
      IF condition
        THEN CONTINUE loop
        ELSE BREAK loop
    };
    BREAK loop
  };
  c <- §{0} + {1} * {2} + {1}§[a, b, d];
  EMIT §{0}§[c];
  STOP
}
