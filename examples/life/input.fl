{
    LET height     = §10§,
        width      = §10§,
        iterations = §100§;

    -- setup board
    FORK x = §FROM range({width})§;
    FORK y = §FROM range({height})§;

    -- initialize "alive" states
    LET alive = §
        ({x}, {y}) = ANY (VALUES
                   ((1,0)),
                            ((2,1)),
          ((0,2)), ((1,2)), ((2,2))
        )
    §;

    LOOP {
        -- "send" a "copy" of the current grid to "rendering"
        FORK flip = §VALUES (TRUE), (FALSE)§;
        IF flip THEN BREAK;

        -- limit iteration count (optional!)
        IF §{iterations} = 0§ THEN STOP ELSE LET iterations = §{iterations} - 1§;

        -- distribute "alive" state to neighboring cells
        FORK dx = §FROM generate_series(-1, 1)§;
        FORK dy = §FROM generate_series(-1, 1)§;
        LET x = §({width}  + {x} + {dx}) % {width}§,
            y = §({height} + {y} + {dy}) % {height}§;

        -- detect state contiaining the orginal "alive" state of current cell
        LET original = §{dx} = 0 AND {dy} = 0§;

        -- count up "living" neighbors
        GATHER neighbors = §count(*) FILTER (WHERE {alive} AND NOT {original})§,
               alive     = §any_value({alive}) FILTER (WHERE {original})§
        BY     x, y;

        -- update "alive" state of current cell
        IF alive
        THEN LET alive = §{neighbors} BETWEEN 2 AND 3§
        ELSE LET alive = §{neighbors} = 3§
    };

    -- render by collapsing state, first into rows, then into a whole grid
    GATHER buffer = §string_agg(if({alive}, '#', '.'), '' ORDER BY {x})§ BY y;
    GATHER buffer = §string_agg({buffer}, E'\n' ORDER BY {y})§;
    EMIT buffer;

    -- (having this spacer after a complete board works wonders for output in `.mode list`)
    LET buffer = §repeat('-', {width})§;
    EMIT buffer
}
