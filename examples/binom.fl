CALL binom(§SELECT 10, 2§[]) IN
FUN binom(n: §hugeint§, k: §hugeint§) -> §hugeint§: {
  num: §hugeint§;
  num <= fac(n);
  n <- §{0} - {1}§[n, k];
  n <= fac(n);
  k <= fac(k);
  k <- §{0} * {1}§[n, k];
  k <- §{0} // {1}§[num, k];
  RETURN k
}

FUN fac(n: §hugeint§) -> §hugeint§: {
  k: §bool§;
  acc: §hugeint§;
  acc <- §1§[];
  LOOP loop {
    k <- §{0} <= 1§[n];
    IF k
    THEN RETURN acc
    ELSE {
      acc <- §{0} * {1}§[acc, n];
      n <- §{0} - 1§[n]
    }
  }
}
