CALL add(§SELECT 4, 10§[]) IN
FUN add(a: §int§, b: §int§) -> §int§: {
  k: §bool§;

  EMIT a;

  k <- §false§[];
  a, b <- §SELECT {0} + 1, {1} - 1§[a, b];
  SPAWN g2 AS add(a, b);
  FETCH g2 INTO a;
  SPAWN g3 AS add(a, b);
  SPAWN g4 AS add(a, b);
  IF VAR k
  THEN JOIN g3
  ELSE JOIN g3;
  JOIN g2;
  JOIN g4;
  STOP
}
