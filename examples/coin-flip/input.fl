{
  DECLARE c : §boolean§;
  DECLARE s : §text§;
  DECLARE i : §int§;
  DECLARE n : §int§;

  LET n = §10§[];

  FORK i = §SELECT * FROM range({0})§[n];

  LET c = §random() >= 0.5§[];
  IF c
  THEN LET s = §'tails'§[]
  ELSE LET s = §'heads'§[];

  GATHER i = §count(*)§[] BY s;
  LET i = §{0} / ({1} :: float)§[i, n];
  GATHER i = §avg({0})§[i];
  EMIT i
}
