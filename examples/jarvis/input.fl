{
    LET p0 = §SELECT arg_min(p, p.x) FROM points AS p§;
    LET p  = p0;

    LOOP {
        EMIT p;
        LET p = §
            SELECT p1
            FROM   points AS p1
            WHERE  p1 <> {p}
            AND    NOT EXISTS (
                     FROM  points AS p2
                     WHERE ({p}.x - p2.x) * (p1.y - p2.y) -
                           ({p}.y - p2.y) * (p1.x - p2.x) > 0
                   )
        §;

        IF §{p} = {p0}§ THEN STOP
    }
}
