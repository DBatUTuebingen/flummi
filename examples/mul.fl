CALL (§4§[], §5§[]) IN
FUN (a: §int§, b: §int§) -> §int§: {
  c: §int§;
  condition: §bool§;

  c <- §0§[];

  LOOP multiplication_loop {
    c <- §{0} + {1}§[a, c];

    EMIT §{0}§[c];

    b <- §{0} - 1§[b];

    condition <- §0 = {0}§[b];
    IF condition
      THEN BREAK multiplication_loop
      ELSE CONTINUE multiplication_loop
  };

  STOP
}
