CALL mul(§SELECT 4, 5§[]) IN
FUN mul(a: §int§, b: §int§) -> §int§: {
  DECLARE c: §int§;
  DECLARE x: §int§;
  DECLARE K: §bool§;

  FORK x = §SELECT x FROM generate_series(1, {0}) AS _(x)§[b];
  LET c = §{0}§[a];

  LOOP multiplication_loop {
    LET x = §{0} - 1§[x];
    LET K = §0 >= {0}§[x];
    IF K
      THEN BREAK multiplication_loop
      ELSE NOOP;
    LET c = §{0} + {1}§[a, c]
  };

  SYNC;

  EMIT c;

  STOP
}
