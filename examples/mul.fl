CALL (§SELECT 4, 10§[]) IN
FUN (a: §int§, b: §int§) -> §int§: {
  c: §int§;
  k: §bool§;

  c <- §0§[];

  LOOP multiplication_loop {
    c, b <- §SELECT {0} + {1}, {2} - 1§[a, c, b];

    EMIT c;

    k <- §0 = {0}§[b];
    IF k
      THEN BREAK multiplication_loop
      ELSE CONTINUE multiplication_loop
  };

  STOP
}
