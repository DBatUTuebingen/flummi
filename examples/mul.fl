CALL mul(§SELECT 4, 5§[]) IN
FUN mul(a: §int§, b: §int§) -> §int§: {
  c: §int§;
  K: §bool§;

  c <- §0§[];

  LOOP multiplication_loop {
    c <- §{0} + {1}§[a, c];

    EMIT c;

    b <- §{0} - 1§[b];
    K <- §0 = {0}§[b];
    IF K
      THEN BREAK multiplication_loop
      ELSE CONTINUE multiplication_loop
  };

  STOP
}
